\ProvidesPackage{memory_blocks}

\newcommand{\@repeatCellcontent}{}
\newcommand{\repeatCell}[2]{%
\renewcommand{\@repeatCellcontent}{}%
\multido{\i=1+1}{\the\numexpr#1-1\relax}{\gappto\@repeatCellcontent{{#2} &}}%
\gappto\@repeatCellcontent{{#2}}%
\@repeatCellcontent
}

\newcommand{\@repeatUnderlineContent}{}
\newcommand{\repeatUnderline}[2]{%
\renewcommand{\@repeatUnderlineContent}{}%
\multido{\i=1+1}{\the\numexpr#1-1\relax}{\gappto\@repeatUnderlineContent{{}&}}%
\gappto\@repeatUnderlineContent{{}\\}%
\gappto\@repeatUnderlineContent{\cline{1-#2}}%
\@repeatUnderlineContent
}

\newcommand{\@underlineblock}[3]{%
\lefteqn{\begin{array}{*{#1}{l}}%
\repeatUnderline{#1}{#2}
\end{array}}{\lefteqn{\scriptstyle#3}}%
}

\newcommand{\@databox}[2]{%
\begin{array}{*{#1}{|c}|}%
\hline%
\repeatCell{#1}{#2}\\%
\hline%
\end{array}%
}

\newcommand{\@emptybox}[1]{\@databox{#1}{}}

\newcommand{\@nothingbox}[1]{\phantom{\@emptybox{#1}}}

\newlength{\@arrayrealwidth}

\newcommand{\@databoxwithunderbrace}[3]{%
\settowidth{\@arrayrealwidth}{$\displaystyle\@emptybox{#1}$}%
\mathmakebox[\@arrayrealwidth][c]{\underbrace{\@databox{#1}{#2}}_{\mathclap{{#3}}}}%
}

\newcommand{\@nothingwithunderbrace}[2]{%
\settowidth{\@arrayrealwidth}{$\displaystyle\@nothingbox{#1}$}%
\mathmakebox[\@arrayrealwidth][c]{
\underbrace{\@nothingbox{#1}}_{\mathclap{{#2}}}}}

\newcommand{\@nothingwithoverbrace}[2]{%
\settowidth{\@arrayrealwidth}{$\displaystyle\@nothingbox{#1}$}%
\mathmakebox[\@arrayrealwidth][c]{
\overbrace{\@nothingbox{#1}}^{\mathclap{{#2}}}}}

\newlength{\@arraycolseptmp}

\newcommand{\datablock}[5] {
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\begin{array}[b]{l}
{\setlength{\arraycolsep}{\@arraycolseptmp}%
\@underlineblock{#1}{#5}{#4}
}\\
\multicolumn{1}{|c}{}\\
{
\setlength{\arraycolsep}{\@arraycolseptmp}\@databoxwithunderbrace{#1}{#2}{#3}}\\
\end{array}
\setlength{\arraycolsep}{\@arraycolseptmp}
}

\newcommand{\emptyblock}[2]{
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\begin{array}[b]{l}
{}\\
{}\\
{\setlength{\arraycolsep}{\@arraycolseptmp}\@databox{#1}{#2}}\\
\end{array}
\setlength{\arraycolsep}{\@arraycolseptmp}
}

\newcommand{\addressblock}[4]{
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\begin{array}[b]{l}
{\setlength{\arraycolsep}{\@arraycolseptmp}%
\@underlineblock{#1}{#4}{#3}}\\
\multicolumn{1}{|c}{}\\
{\setlength{\arraycolsep}{\@arraycolseptmp}\@databox{#1}{#2}}\\
\end{array}
\setlength{\arraycolsep}{\@arraycolseptmp}
}

\newcommand{\note}[2]{
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\lefteqn{\begin{array}[b]{l}
{\setlength{\arraycolsep}{\@arraycolseptmp}%
\@underlineblock{#1}{#1}{#2}}\\
\multicolumn{1}{|c}{}\\
{}\\
\end{array}}
\setlength{\arraycolsep}{\@arraycolseptmp}
}

\newcommand{\@repeatUnderlineRContent}{}
\newcommand{\repeatUnderlineR}[2]{%
\renewcommand{\@repeatUnderlineRContent}{}%
\multido{\i=1+1}{\the\numexpr#1-1\relax}{\gappto\@repeatUnderlineRContent{{}&}}%
\gappto\@repeatUnderlineRContent{{}\\}%
\gappto\@repeatUnderlineRContent{%
\hline}%
\@repeatUnderlineRContent
}

\newcommand{\@underlineblockr}[2]{\mathmakebox[0cm][r]{
\begin{array}{*{#1}{l}}%
\repeatUnderline{#1}{#1}
\end{array}}\mathmakebox[0cm][r]{\scriptstyle#2}%
}

\newlength{\@widthtmp}

\newcommand{\@underlineblockrr}[2]{%
\settowidth{\@widthtmp}{$\displaystyle\begin{array}{*{#1}{l}}\repeatUnderline{#1}{#1}\end{array}$}
\addtolength{\@widthtmp}{1pt}
\lefteqn{\mathmakebox[-\@widthtmp][r]{\begin{array}{*{#1}{l}}%
\repeatUnderline{#1}{#1}
\end{array}}}{\mathmakebox[-\@widthtmp][r]{\scriptstyle#2}}%
}

\newcommand{\noteleft}[2]{
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\lefteqn{\begin{array}[b]{r}
{\setlength{\arraycolsep}{\@arraycolseptmp}%
\lefteqn{\@underlineblockrr{#1}{#2}}
}\\
\multicolumn{1}{|c}{}\\
{
\setlength{\arraycolsep}{\@arraycolseptmp}%
\@nothingbox{#1}
}\\
\end{array}}
\setlength{\arraycolsep}{\@arraycolseptmp}
}

\newcommand{\noteblock}[4]{
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\begin{array}[b]{l}
{\setlength{\arraycolsep}{\@arraycolseptmp}%
\@underlineblock{#1}{#4}{#3}}\\
\multicolumn{1}{|c}{}\\
{\setlength{\arraycolsep}{\@arraycolseptmp}\@databox{#1}{#2}}\\
\end{array}
\setlength{\arraycolsep}{\@arraycolseptmp}
}

\newcommand{\noteunder}[2]{
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\lefteqn{\begin{array}[b]{l}
{}\\
{}\\
{\setlength{\arraycolsep}{\@arraycolseptmp}%
\@nothingwithunderbrace{#1}{#2}}\\
\end{array}}
\setlength{\arraycolsep}{\@arraycolseptmp}
}

\newcommand{\noteover}[2]{
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\lefteqn{\begin{array}[b]{l}
{}\\
{}\\
{\setlength{\arraycolsep}{\@arraycolseptmp}%
\@nothingwithoverbrace{#1}{#2}}\\
\end{array}}
\setlength{\arraycolsep}{\@arraycolseptmp}
}

