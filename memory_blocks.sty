\newcommand{\nothingblock}[1] {
\setlength{\@arraycolseptmp}{\arraycolsep}
\setlength{\arraycolsep}{0pt}
\begin{array}[b]{l}
{
}\\
{}\\
{
\setlength{\arraycolsep}{\@arraycolseptmp}\@nothingbox{#1}}\\
\end{array}
\setlength{\arraycolsep}{\@arraycolseptmp}
}
